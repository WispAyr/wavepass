# WavePass — Environment Variables

# ─── Server ───────────────────────────────────────────────────
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string

# ─── Admin Credentials (initial setup) ───────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# ─── UniFi UDM Pro Connectivity ───────────────────────────────
#
# Option A — WireGuard tunnel (RECOMMENDED for remote deployments)
#   Set UNIFI_HOST to the UDM Pro's WireGuard peer IP.
#   The WavePass server and UDM Pro must be WireGuard peers.
#   Example: if UDM Pro is assigned 10.10.0.1 in the WG network:
#
UNIFI_HOST=https://10.10.0.1
#
# Option B — Bridge agent on same LAN (no WireGuard)
#   Run bridge/agent.js on any machine on the UDM Pro's LAN,
#   then set UNIFI_MODE=bridge and point at the bridge URL.
#
# UNIFI_MODE=bridge
# BRIDGE_URL=http://your-bridge-host:4000
# BRIDGE_SECRET=a-long-random-shared-secret

UNIFI_USERNAME=api-admin
UNIFI_PASSWORD=your-unifi-local-admin-password
UNIFI_SITE=default

# ─── App Settings ─────────────────────────────────────────────
APP_BASE_URL=https://wavepass.wispayr.online

# Name of the guest WiFi SSID (shown on redemption page)
WIFI_SSID=Guest WiFi

# Display name shown throughout the UI
VENUE_NAME=My Venue
