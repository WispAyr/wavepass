# UniFi QR Access Control — Environment Variables

# ─── Server ───────────────────────────────────────────────
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string

# ─── Admin Credentials (initial setup) ───────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# ─── UniFi UDM Pro ────────────────────────────────────────
UNIFI_HOST=https://192.168.1.1
UNIFI_USERNAME=api-admin
UNIFI_PASSWORD=your-unifi-local-admin-password
UNIFI_SITE=default

# ─── App Settings ─────────────────────────────────────────
# Public base URL (used for QR code links)
APP_BASE_URL=http://localhost:3000

# Name of the guest WiFi SSID (shown on redemption page)
WIFI_SSID=Guest WiFi

# Optional: Name shown in UI
VENUE_NAME=My Venue
